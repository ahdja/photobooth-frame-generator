{
  "name": "photobooth-frame-generator",
  "version": "1.0.0",
  "description": "A fast and efficient engine to automate placing user photos into a frame's transparent slots.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
