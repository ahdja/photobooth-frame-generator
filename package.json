    "canvas",
    "image-processing",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "jsdom": "^29.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
